---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { loomlance, profile } from "../data/resume";
---

<BaseLayout
  title={`Loomlance — Case Study · ${profile.name}`}
  description="How Mahmoud Sabbagh took Loomlance from concept to a live SaaS in eight months as Product Owner and Scrum Master — discovery, adaptive Scrum, release management, and a real quality gate."
  path="/loomlance"
>
  <span id="top"></span>
  <Nav />
  <main id="main">
    <!-- Hero -->
    <section class="relative overflow-hidden pt-32 sm:pt-40">
      <div class="pointer-events-none absolute -right-[10%] -top-[6%] -z-10 h-[36rem] w-[36rem] rounded-full opacity-50 blur-[90px]" style="background: radial-gradient(closest-side, var(--primary-soft), transparent 72%);" aria-hidden="true"></div>
      <div class="container-page">
        <a href="/#loomlance" class="group inline-flex items-center gap-2 text-[16px] font-medium text-muted transition-colors hover:text-ink">
          <svg class="h-4 w-4 transition-transform group-hover:-translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M11 18l-6-6 6-6" /></svg>
          Back to portfolio
        </a>

        <div class="mt-8 max-w-3xl">
          <p data-reveal class="flex items-center gap-2.5 text-[14.5px] font-semibold text-primary-ink">
            <span class="h-px w-6 bg-primary"></span>
            Case Study · Product Ownership
          </p>
          <h1 data-reveal style="--reveal-delay:60ms" class="mt-4 font-display text-[clamp(2.4rem,7vw,4.2rem)] font-semibold leading-[1] tracking-[-0.035em] text-ink">
            {loomlance.name}
          </h1>
          <p data-reveal style="--reveal-delay:120ms" class="mt-5 text-xl leading-relaxed text-muted">{loomlance.tagline}</p>
          <p data-reveal style="--reveal-delay:160ms" class="mt-5 max-w-2xl text-lg leading-relaxed text-muted">{loomlance.intro}</p>

          <div data-reveal style="--reveal-delay:220ms" class="mt-8 flex flex-wrap items-center gap-3">
            <a href={loomlance.url} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-primary px-5 py-3 text-[17px] font-semibold text-on-primary shadow-[var(--shadow-md)] transition-transform hover:-translate-y-0.5">
              Visit loomlance.com
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M8 7h9v9" /></svg>
            </a>
            <div class="flex flex-wrap gap-2">
              {loomlance.stack.map((s) => (
                <span class="rounded-full border border-line bg-surface px-3.5 py-2 text-[15.5px] font-medium text-ink">{s}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Stats -->
        <div data-reveal class="mt-16 grid grid-cols-2 overflow-hidden rounded-2xl border border-line bg-surface lg:grid-cols-4">
          {loomlance.stats.map((s, i) => (
            <div class={`p-7 ${i < 2 ? "border-b border-line" : ""} ${i % 2 === 0 ? "border-r border-line" : ""} lg:border-b-0 ${i < 3 ? "lg:border-r" : ""}`}>
              <p class="font-display text-[clamp(2rem,4vw,2.8rem)] font-semibold leading-none tracking-[-0.03em] text-primary-ink tabular">{s.value}</p>
              <p class="mt-2.5 text-[16px] text-muted">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Chapters: a real sequence, so numbered markers are earned -->
    <section class="section-pad">
      <div class="container-page">
        <h2 data-reveal class="mb-12 max-w-2xl font-display text-[clamp(1.8rem,4vw,2.6rem)] font-semibold tracking-[-0.03em] text-ink">
          How it was built — concept to launch
        </h2>

        <ol class="space-y-px overflow-hidden rounded-2xl border border-line">
          {loomlance.chapters.map((c, i) => (
            <li data-reveal style={`--reveal-delay:${i * 70}ms`} class="grid grid-cols-1 gap-5 bg-surface p-7 sm:grid-cols-[5rem_1fr] sm:gap-10 sm:p-10">
              <span class="font-display text-[2.4rem] font-semibold leading-none tracking-[-0.03em] text-primary-ink/35 tabular">{String(i + 1).padStart(2, "0")}</span>
              <div>
                <h3 class="font-display text-xl font-semibold tracking-[-0.02em] text-ink">{c.title}</h3>
                <p class="mt-3 max-w-2xl text-[17px] leading-relaxed text-muted">{c.body}</p>
              </div>
            </li>
          ))}
        </ol>

        <!-- Closing CTA -->
        <div data-reveal class="mt-16 flex flex-col items-start justify-between gap-6 rounded-2xl border border-line bg-surface p-8 sm:flex-row sm:items-center sm:p-10">
          <div>
            <h3 class="font-display text-xl font-semibold text-ink">Want this kind of ownership on your team?</h3>
            <p class="mt-2 text-[17px] text-muted">I bring the same discovery-first, ship-it discipline to delivery and product roles.</p>
          </div>
          <a href="/#contact" class="inline-flex shrink-0 items-center gap-2 rounded-full bg-primary px-6 py-3.5 text-[17px] font-semibold text-on-primary shadow-[var(--shadow-md)] transition-transform hover:-translate-y-0.5">
            Get in touch
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
