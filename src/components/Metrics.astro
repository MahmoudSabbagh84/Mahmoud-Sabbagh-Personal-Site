---
import { metrics } from "../data/resume";
---

<section id="impact" class="scroll-mt-24">
  <div class="container-page">
    <div class="overflow-hidden rounded-[1.75rem] border border-line bg-surface">
      <div class="border-b border-line px-7 py-6 sm:px-10">
        <p data-reveal class="flex items-center gap-2.5 text-[13px] font-semibold text-primary">
          <span class="h-px w-6 bg-primary"></span>
          Impact at a glance
        </p>
        <p data-reveal class="mt-2 max-w-2xl text-lg text-ink">
          Four numbers that summarize the work. Each one earned and held, not a one-off spike.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
        {metrics.map((m, i) => (
          <div
            data-reveal
            style={`--reveal-delay:${i * 90}ms`}
            class="group relative border-line p-7 sm:px-8 sm:py-9 [&:not(:last-child)]:border-b sm:[&:nth-child(odd)]:border-r lg:[&:not(:last-child)]:border-r lg:[&:nth-child(2)]:border-r"
          >
            <p class="font-display text-[clamp(2.6rem,5vw,3.4rem)] font-semibold leading-none tracking-[-0.04em] text-ink tabular">
              {m.value}<span class="text-primary">{m.unit}</span>
            </p>
            <p class="mt-3 font-display text-[15px] font-semibold text-ink">{m.label}</p>
            <p class="mt-2 text-[14px] leading-relaxed text-muted">{m.context}</p>
            <span class="absolute bottom-0 left-0 h-[2px] w-0 bg-primary transition-[width] duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:w-full"></span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
