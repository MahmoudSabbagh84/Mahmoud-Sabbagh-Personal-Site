---
import { metrics } from "../data/resume";
---

<section id="impact" class="scroll-mt-24">
  <div class="container-page">
    <div class="overflow-hidden rounded-[1.75rem] border border-line bg-surface">
      <div class="border-b border-line px-7 py-6 sm:px-10">
        <p data-reveal class="flex items-center gap-2.5 text-[19px] font-semibold text-primary-ink">
          <span class="h-px w-6 bg-primary"></span>
          Impact at a glance
        </p>
        <p data-reveal class="mt-2 max-w-2xl text-[1.46rem] text-ink">
          Four numbers that summarize the work. Each one earned and held, not a one-off spike.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4">
        {metrics.map((m, i) => {
          // Count up only clean integers; "60→85" already reads as motion, leave it.
          const countTo = /^\d+$/.test(m.value) ? m.value : null;
          return (
          <div
            data-reveal
            style={`--reveal-delay:${i * 90}ms`}
            class="group relative border-line p-7 sm:px-8 sm:py-9 [&:not(:last-child)]:border-b sm:[&:nth-child(odd)]:border-r xl:[&:not(:last-child)]:border-r xl:[&:nth-child(2)]:border-r"
          >
            <p class="flex items-baseline font-display text-[clamp(2.1rem,3.7vw,2.9rem)] font-semibold leading-none tracking-[-0.035em] text-ink tabular">
              <span class="metric-num" data-count={countTo}>{m.value}</span><span class="ml-0.5 text-[0.58em] font-semibold tracking-normal text-primary-ink">{m.unit}</span>
            </p>
            <p class="mt-3 font-display text-[22px] font-semibold text-ink">{m.label}</p>
            <p class="mt-2 text-[21px] leading-relaxed text-muted">{m.context}</p>
            <span class="absolute bottom-0 left-0 h-[2px] w-0 bg-primary transition-[width] duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:w-full"></span>
          </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var band = document.getElementById("impact");
    if (!band) return;
    var nums = band.querySelectorAll("[data-count]");
    if (!nums.length) return;
    var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    var run = function () {
      nums.forEach(function (el) {
        var target = parseInt(el.getAttribute("data-count"), 10);
        if (isNaN(target)) return;
        if (reduce) { el.textContent = String(target); return; }
        var dur = 1100, started = null;
        var step = function (t) {
          if (started === null) started = t;
          var p = Math.min((t - started) / dur, 1);
          var eased = 1 - Math.pow(1 - p, 3);
          el.textContent = String(Math.round(eased * target));
          if (p < 1) requestAnimationFrame(step);
          else el.textContent = String(target);
        };
        requestAnimationFrame(step);
      });
    };

    if (reduce || !("IntersectionObserver" in window)) { run(); return; }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { run(); io.disconnect(); }
      });
    }, { threshold: 0.35 });
    io.observe(band);
  })();
</script>
