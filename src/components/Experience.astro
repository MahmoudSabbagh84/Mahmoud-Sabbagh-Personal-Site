---
import { experience } from "../data/resume";
---

<section id="experience" class="section-pad scroll-mt-24">
  <div class="container-page">
    <div class="mb-14">
      <p data-reveal class="mb-3 flex items-center gap-2.5 text-[13px] font-semibold text-primary">
        <span class="h-px w-6 bg-primary"></span>
        Experience
      </p>
      <h2 data-reveal class="font-display text-[clamp(1.9rem,4.5vw,3rem)] font-semibold tracking-[-0.03em] text-ink">
        A track record of measurable delivery
      </h2>
    </div>

    <ol class="relative">
      <!-- Timeline rail -->
      <span class="absolute left-[7px] top-2 bottom-2 w-px bg-line md:left-[calc(11rem+7px)]" aria-hidden="true"></span>

      {experience.map((job, i) => (
        <li data-reveal style={`--reveal-delay:${Math.min(i, 4) * 60}ms`} class="relative grid grid-cols-1 gap-x-8 gap-y-3 pb-12 pl-9 last:pb-0 md:grid-cols-[11rem_1fr] md:pl-0">
          <!-- Node -->
          <span class={`absolute left-0 top-1.5 grid h-[15px] w-[15px] place-items-center rounded-full border-2 ${job.current ? "border-primary bg-primary" : "border-line-strong bg-bg"} md:left-44`} aria-hidden="true">
            {job.current && <span class="h-[5px] w-[5px] rounded-full bg-on-primary"></span>}
          </span>

          <!-- Period column -->
          <div class="md:pr-10 md:text-right">
            <p class="font-display text-[14px] font-semibold text-ink tabular">{job.period}</p>
            <p class="mt-0.5 text-[13px] text-muted">{job.location}</p>
            {job.current && (
              <span class="mt-2 inline-flex items-center gap-1.5 rounded-full bg-primary-soft px-2.5 py-0.5 text-[11.5px] font-semibold text-primary">
                <span class="h-1.5 w-1.5 rounded-full bg-primary"></span> Now
              </span>
            )}
          </div>

          <!-- Detail column -->
          <div class="md:pl-10">
            <h3 class="font-display text-xl font-semibold tracking-[-0.02em] text-ink">{job.role}</h3>
            <p class="mt-0.5 text-[15px] font-medium text-primary">{job.org}</p>
            {job.summary && <p class="mt-3 max-w-2xl text-[15px] italic leading-relaxed text-muted">{job.summary}</p>}
            <ul class="mt-4 space-y-2.5">
              {job.highlights.map((h) => (
                <li class="flex gap-3 text-[15px] leading-relaxed text-muted">
                  <svg class="mt-[7px] h-2.5 w-2.5 shrink-0 text-primary" viewBox="0 0 8 8" aria-hidden="true"><circle cx="4" cy="4" r="2.2" fill="currentColor" /></svg>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
