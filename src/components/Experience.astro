---
import { experience } from "../data/resume";
---

<section id="experience" class="section-pad scroll-mt-24">
  <div class="container-page">
    <div class="mb-14">
      <p data-reveal class="mb-3 flex items-center gap-2.5 text-[19px] font-semibold text-primary-ink">
        <span class="h-px w-6 bg-primary"></span>
        Experience
      </p>
      <h2 data-reveal class="font-display text-[clamp(2.47rem,5.85vw,3.9rem)] font-semibold tracking-[-0.03em] text-ink">
        A track record of measurable delivery
      </h2>
    </div>

    <ol class="relative">
      <!-- Timeline rail -->
      <span class="exp-rail absolute left-[7px] top-2 bottom-2 w-px bg-line md:left-[calc(11rem+7px)]" aria-hidden="true"></span>

      {experience.map((job, i) => (
        <li data-reveal style={`--reveal-delay:${Math.min(i, 4) * 60}ms`} class="group relative grid grid-cols-1 gap-x-8 gap-y-3 pb-12 pl-9 last:pb-0 md:grid-cols-[11rem_1fr] md:pl-0">
          <!-- Node -->
          <span class={`absolute left-0 top-1.5 grid h-[15px] w-[15px] place-items-center rounded-full border-2 transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] ${job.current ? "border-primary bg-primary" : "border-line-strong bg-bg group-hover:scale-110 group-hover:border-primary"} md:left-44`} aria-hidden="true">
            {job.current && <span class="h-[5px] w-[5px] rounded-full bg-on-primary"></span>}
          </span>

          <!-- Period column -->
          <div class="md:pr-10 md:text-right">
            <p class="font-display text-[21px] font-semibold text-ink tabular">{job.period}</p>
            <p class="mt-0.5 text-[19px] text-muted">{job.location}</p>
            {job.current && (
              <span class="mt-2 inline-flex items-center gap-1.5 rounded-full bg-primary-soft px-2.5 py-0.5 text-[17.5px] font-semibold text-primary-ink">
                <span class="h-1.5 w-1.5 rounded-full bg-primary"></span> Now
              </span>
            )}
          </div>

          <!-- Detail column -->
          <div class="md:pl-10">
            <h3 class="font-display text-[1.63rem] font-semibold tracking-[-0.02em] text-ink">{job.role}</h3>
            <p class="mt-0.5 text-[22px] font-medium text-primary-ink">{job.org}</p>
            {job.summary && <p class="mt-3 max-w-2xl text-[22px] italic leading-relaxed text-muted">{job.summary}</p>}
            <ul class="mt-4 space-y-2.5">
              {job.highlights.map((h) => (
                <li class="flex gap-3 text-[22px] leading-relaxed text-muted">
                  <svg class="mt-[7px] h-2.5 w-2.5 shrink-0 text-primary-ink" viewBox="0 0 8 8" aria-hidden="true"><circle cx="4" cy="4" r="2.2" fill="currentColor" /></svg>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<script is:inline>
  (function () {
    var rail = document.querySelector(".exp-rail");
    if (!rail) return;
    var list = rail.closest("ol");
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches || !("IntersectionObserver" in window) || !list) {
      rail.classList.add("is-in");
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { rail.classList.add("is-in"); io.disconnect(); }
      });
    }, { threshold: 0.12 });
    io.observe(list);
  })();
</script>
