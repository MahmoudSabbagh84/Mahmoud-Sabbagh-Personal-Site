---
import { certifications, skillGroups, languages } from "../data/resume";
---

<section id="credentials" class="section-pad scroll-mt-24">
  <div class="container-page">
    <div class="grid grid-cols-1 gap-14 lg:grid-cols-[1fr_1fr] lg:gap-20">
      <!-- Certifications -->
      <div>
        <p data-reveal class="mb-3 flex items-center gap-2.5 text-[13.5px] font-semibold text-primary-ink">
          <span class="h-px w-6 bg-primary"></span>
          Certifications
        </p>
        <h2 data-reveal class="font-display text-[clamp(1.7rem,4vw,2.4rem)] font-semibold tracking-[-0.03em] text-ink">
          Credentials, kept current
        </h2>

        <ul class="mt-8 divide-y divide-line border-t border-line">
          {certifications.map((c, i) => (
            <li data-reveal style={`--reveal-delay:${Math.min(i, 6) * 45}ms`} class="flex items-center justify-between gap-4 py-4">
              <div class="min-w-0">
                <p class="font-display text-[16px] font-semibold text-ink">{c.name}</p>
                <p class="text-[14.5px] text-muted">{c.issuer}</p>
              </div>
              <div class="flex shrink-0 items-center gap-3">
                <span class="text-right text-[13px] font-medium text-muted tabular">{c.meta}</span>
                {c.inProgress ? (
                  <span class="h-2 w-2 rounded-full bg-line-strong" title="In progress" aria-label="In progress"></span>
                ) : (
                  <svg class="h-[18px] w-[18px] text-primary-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
                )}
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Skills + Languages -->
      <div>
        <p data-reveal class="mb-3 flex items-center gap-2.5 text-[13.5px] font-semibold text-primary-ink">
          <span class="h-px w-6 bg-primary"></span>
          Skills
        </p>
        <h2 data-reveal class="font-display text-[clamp(1.7rem,4vw,2.4rem)] font-semibold tracking-[-0.03em] text-ink">
          What I bring to a team
        </h2>

        <div class="mt-8 space-y-6">
          {skillGroups.map((g, i) => (
            <div data-reveal style={`--reveal-delay:${i * 70}ms`}>
              <p class="font-display text-[15px] font-semibold text-ink">{g.title}</p>
              <ul class="mt-3 flex flex-wrap gap-2">
                {g.skills.map((s) => (
                  <li class="rounded-full border border-line bg-surface px-3.5 py-1.5 text-[14.5px] font-medium text-ink transition-colors hover:border-primary hover:text-primary-ink">{s}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <!-- Languages -->
        <div data-reveal class="mt-10 border-t border-line pt-7">
          <p class="font-display text-[15px] font-semibold text-ink">Languages</p>
          <p class="mt-3 max-w-md text-[16px] leading-relaxed text-muted">
            <span class="font-medium text-ink">Bilingual</span> in
            <span class="font-medium text-ink">{languages.bilingual[0]}</span> and
            <span class="font-medium text-ink">{languages.bilingual[1]}</span>, and a beginner in
            <span class="font-medium text-ink">{languages.beginner[0]}</span>.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
