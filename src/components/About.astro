---
import { about, profile, education } from "../data/resume";
---

<section id="about" class="section-pad scroll-mt-24">
  <div class="container-page">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:gap-20">
      <div data-reveal>
        <p class="mb-3 flex items-center gap-2.5 text-[19px] font-semibold text-primary-ink">
          <span class="h-px w-6 bg-primary"></span>
          About
        </p>
        <h2 class="font-display text-[clamp(2.47rem,5.85vw,3.9rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-ink">
          People, process,
          <span class="text-primary-ink">and the numbers</span>
          that prove it.
        </h2>
      </div>

      <div>
        <div class="max-w-[60ch] space-y-5 text-[1.46rem] leading-relaxed text-muted">
          {about.map((para, i) => (
            <p data-reveal style={`--reveal-delay:${i * 80}ms`} class="[&_strong]:font-semibold [&_strong]:text-ink">
              <Fragment set:html={para.replace(/(85%\+|~65%|perfect CSAT|PSM I, PSPO I|Loomlance)/g, "<strong>$1</strong>")} />
            </p>
          ))}
        </div>

        <div data-reveal class="mt-8 flex flex-wrap items-center gap-x-8 gap-y-3 border-t border-line pt-6 text-[20px]">
          <div>
            <span class="font-semibold uppercase tracking-[0.12em] text-[17px] text-primary-ink">Education</span>
            <span class="ml-2 font-medium text-ink">{education.degree}</span>
          </div>
          <div class="text-muted">{education.school} · {education.period}</div>
        </div>
      </div>
    </div>
  </div>
</section>
